# shift + alt - f : yabai -m window --toggle zoom-fullscreen
# shift + alt - e : yabai -m space --balance

# ctrl + alt - j : yabai -m window --warp south
# ctrl + alt - k : yabai -m window --warp north
# ctrl + alt - h : yabai -m window --warp west
# ctrl + alt - l : yabai -m window --warp east

# shift + alt - y : yabai -m space --mirror y-axis
# shift + alt - x : yabai -m space --mirror x-axis
# shift + alt - c : yabai -m window --toggle float --grid 4:4:1:1:2:2

# shift + alt - s : yabai -m window --display west; yabai -m display --focus west;
# shift + alt - g : yabai -m window --display east; yabai -m display --focus east;
#
shift + alt - r : yabai -m space --rotate 270

shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - h : yabai -m window --swap west
shift + alt - l : yabai -m window --swap east

alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east

shift + ctrl - p : yabai -m window --space prev && yabai -m space --focus prev;
shift + ctrl - n : yabai -m window --space next && yabai -m space --focus next;

shift + ctrl - 1 : yabai -m window --space 1 && yabai -m space --focus 1;
shift + ctrl - 2 : yabai -m window --space 2 && yabai -m space --focus 2;
shift + ctrl - 3 : yabai -m window --space 3 && yabai -m space --focus 3;
shift + ctrl - 4 : yabai -m window --space 4 && yabai -m space --focus 4;
shift + ctrl - 5 : yabai -m window --space 5 && yabai -m space --focus 5;
shift + ctrl - q : yabai -m window --space 6 && yabai -m space --focus 6;
shift + ctrl - w : yabai -m window --space 7 && yabai -m space --focus 7;
shift + ctrl - e : yabai -m window --space 8 && yabai -m space --focus 8;

alt - p : yabai -m space --focus prev;
alt - n : yabai -m space --focus next;

alt - 1 : "${HOME}"/.config/skhd/scripts/effect 1;
alt - 2 : "${HOME}"/.config/skhd/scripts/effect 2;
alt - 3 : "${HOME}"/.config/skhd/scripts/effect 3;
alt - 4 : "${HOME}"/.config/skhd/scripts/effect 4;
alt - 5 : "${HOME}"/.config/skhd/scripts/effect 5;
alt - q : "${HOME}"/.config/skhd/scripts/effect 6;
alt - w : "${HOME}"/.config/skhd/scripts/effect 7;
alt - e : "${HOME}"/.config/skhd/scripts/effect 8;
alt - r : yabai -m space --focus 9

shift + alt - m : yabai -m space --layout $(yabai -m query --spaces --space | jq -r 'if .type == "stack" then "bsp" elif .type == "bsp" then "float" else "stack" end')

shift + alt - 1 : /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --profile-directory="Default" --new-window
shift + alt - 2 : /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --profile-directory="Profile 1" --new-window
shift + alt - 3 : /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --profile-directory="Profile 6" --new-window
shift + alt - e : open -na /Applications/Alacritty.app

ctrl + alt - q : yabai --stop-service
ctrl + alt - s : yabai --start-service
ctrl + alt - r : yabai --restart-service
